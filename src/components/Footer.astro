---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} nopo</span>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2rem 0;
		margin-top: 4rem;
	}
	footer span {
		display: block;
		width: var(--max-width);
		max-width: calc(100% - 2rem);
		margin: 0 auto;
		font-size: 0.85rem;
		color: var(--text-muted);
	}
</style>
