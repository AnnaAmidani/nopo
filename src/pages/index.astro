---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const cardAccents = ['var(--accent)', 'var(--accent-sage)', 'var(--accent-lavender)', 'var(--accent-peach)'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Welcome to</p>
				<h1>{SITE_TITLE}</h1>
				<p class="tagline">{SITE_DESCRIPTION}</p>
			</section>

			<section class="recent">
				<h2 class="section-label"><span>Recent Posts</span></h2>
				<ul>
					{posts.map((post, i) => (
						<li>
							<a href={`/blog/${post.id}/`} style={`--card-accent: ${cardAccents[i % cardAccents.length]}`}>
								<div class="card-meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
								<div class="card-title">{post.data.title}</div>
								{post.data.description && (
									<div class="card-desc">{post.data.description}</div>
								)}
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="all-posts">All posts →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		padding: 4rem 0 3rem;
		margin-bottom: 3rem;
	}
	.eyebrow {
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--accent);
		margin: 0 0 0.75rem;
	}
	.hero h1 {
		font-size: 4.5rem;
		font-style: italic;
		margin: 0 0 1.25rem;
		line-height: 1;
	}
	.tagline {
		font-size: 1.1rem;
		color: var(--text-muted);
		max-width: 440px;
		margin: 0 auto;
		line-height: 1.6;
	}
	.section-label {
		display: flex;
		align-items: center;
		gap: 1rem;
		font-family: 'Nunito', sans-serif;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 1.5rem;
	}
	.section-label::before,
	.section-label::after {
		content: '';
		flex: 1;
		height: 1px;
		background: var(--border);
	}
	ul {
		list-style: none;
		margin: 0 0 2rem;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}
	ul li a {
		display: block;
		padding: 1.25rem 1.5rem;
		background: var(--bg-card);
		border-radius: var(--radius);
		border: 1px solid var(--border);
		border-left: 4px solid var(--card-accent);
		text-decoration: none;
		color: inherit;
		box-shadow: var(--shadow);
		transition: transform 0.2s, box-shadow 0.2s;
	}
	ul li a:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-hover);
		text-decoration: none;
	}
	.card-meta {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-muted);
		margin-bottom: 0.35rem;
	}
	.card-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.4rem;
		font-weight: 600;
		color: var(--text);
		line-height: 1.3;
		margin-bottom: 0.35rem;
	}
	.card-desc {
		font-size: 0.88rem;
		color: var(--text-muted);
		line-height: 1.5;
	}
	.all-posts {
		display: inline-block;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
		padding: 0.5rem 1.35rem;
		border: 1.5px solid var(--accent);
		border-radius: 99px;
		transition: all 0.2s;
		letter-spacing: 0.02em;
	}
	.all-posts:hover {
		background: var(--accent);
		color: white;
		text-decoration: none;
	}
	@media (max-width: 600px) {
		.hero h1 { font-size: 3rem; }
	}
</style>
